# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mahjong

# Redis
# Option 1 (recommended for Aiven): full connection URL
# REDIS_URL=rediss://user:password@hostname:port
# Option 2: individual fields
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
# Set to 'true' if using individual fields with TLS (e.g. Aiven Redis)
REDIS_TLS=false

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d

# App
PORT=3000

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=something